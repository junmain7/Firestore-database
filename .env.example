# ============================================================
# CONTROL PLANE FIREBASE PROJECT
# This is ONE Firebase project that stores your gateway's own
# metadata: registered projects, API keys, rate-limit counters.
# Create a dedicated Firebase project for this (e.g. "my-gateway-control").
# Go to Project Settings > Service Accounts > Generate new private key.
# Paste the ENTIRE JSON as a single line here.
# ============================================================
CONTROL_FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","...":"..."}

# ============================================================
# MASTER ENCRYPTION KEY
# Used to encrypt every other project's service account JSON
# before it is stored in the control plane database.
# Generate with: openssl rand -hex 32
# ============================================================
MASTER_ENCRYPTION_KEY=

# ============================================================
# ADMIN DASHBOARD LOGIN (real Firebase Auth, not a shared secret)
# Enable Google as a Sign-in provider on the CONTROL PLANE project:
#   Firebase Console > Authentication > Sign-in method > Google > Enable
# Then add your Vercel domain under Authentication > Settings > Authorized domains.
# ============================================================

# Comma-separated list of emails allowed to use the dashboard/admin API.
# Only these Google accounts can log in, regardless of who signs in.
ADMIN_EMAILS=you@gmail.com

# Public web config for the control-plane project (safe to expose to the browser —
# get these from Firebase Console > Project Settings > General > Your apps > SDK setup).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-control-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-control-project

# ============================================================
# GOOGLE OAUTH (for the centralized "Login with Google" broker)
# Create ONE OAuth 2.0 Client (Web application) in Google Cloud Console.
# Authorized redirect URI must be:
#   https://<your-vercel-domain>/api/auth/google/callback
# This is the ONLY domain you will ever need to verify, forever.
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-vercel-domain.vercel.app/api/auth/google/callback

# Used to sign short-lived state tokens during the OAuth redirect dance
OAUTH_STATE_SECRET=
